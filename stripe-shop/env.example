STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Public URL where this server is reachable from the internet.
# Used to build Stripe success/cancel redirect pages (which then deep-link back).
PUBLIC_BASE_URL=https://your-domain.com

# Deep-link scheme registered in the iOS app (see ios/BudgetApp/Info.plist).
APP_DEEPLINK_SCHEME=petrone

